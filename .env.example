OPENAI_API_KEY=sk-your-openai-api-key-here

# Set to 1 only for local testing without login
# DISABLE_AUTH=1

# Optional: long-lived login tokens on Vercel (set a stable value — do not tie to OPENAI_API_KEY)
# SESSION_SECRET=your-random-secret

# Vercel Blob — required on Vercel for persistent accounts and voice samples
# Create a Blob store in Vercel → Storage; this token is added automatically
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Optional: ElevenLabs voice cloning for personal translation audio
# ELEVENLABS_API_KEY=your-elevenlabs-api-key
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
PORT=3001
